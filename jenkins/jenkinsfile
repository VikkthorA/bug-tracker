pipeline {
    agent any

    stages {
        stage('Unit Tests - Backend') {
            agent {
                docker {
                    image 'snakee/golang-junit:1.21' // what it does is to run the tests and generate a junit report without the need to install go and junit in the jenkins agent
                    reuseNode true
                    args '-e GOCACHE=/tmp/go-cache -e GOPATH=/tmp/gopath' // used for caching the go modules and dependencies to speed up the tests               
                }
            }
            steps {
                dir('bugtracker-backend') {
                    sh 'go test -v ./... 2>&1| go-junit-report > test-results.xml' // run the tests and generate a junit report
                }
            }
            post { 
                always {
                    junit 'bugtracker-backend/test-results.xml' // publish the test results in the jenkins dashboard
                }
            }
        }
        stage('Unit Tests - Frontend') {
            agent {
                docker {
                    image 'node:20-alpine' // what it does is to run the tests and generate a junit report without the need to install node and npm in the jenkins agent
                    reuseNode true
                }
            }
            steps {
                dir('bugtracker-frontend') {
                    sh '''
                    npm ci
                    npm test
                    '''
                }
            }
            post { // post is used for actions that should be executed after the steps are completed, regardless of whether they succeed or fail
                always {
                    junit 'bugtracker-frontend/test-results.xml' // publish the test results in the jenkins dashboard
                }
            }
        }
    }
}