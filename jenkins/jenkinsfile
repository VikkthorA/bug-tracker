pipeline {
    agent any

    stages {
        stage('Unit Tests - Backend') {
            agent {
                docker {
                    image 'snakee/golang-junit:1.21' // what it does is to run the tests and generate a junit report without the need to install go and junit in the jenkins agent
                    reuseNode true
                }
            }
            environment {
                GOCACHE = '/tmp/gocache'
            }
            steps {
                dir('bugtracker-backend')
                {
                    sh 'go test -v ./...'
                }
            }
        }
    }
}
