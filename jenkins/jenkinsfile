pipeline {
    agent any

    stages {
        stage('Execute Unit Tests') {
            parallel {
                stage('Unit Tests - Backend') {
                    agent {
                        docker {
                            image 'snakee/golang-junit:1.21' // what it does is to run the tests and generate a junit report without the need to install go and junit in the jenkins agent
                            reuseNode true
                            args '-e GOCACHE=/tmp/go-cache -e GOPATH=/tmp/gopath' // used for caching the go modules and dependencies to speed up the tests               
                        }
                    } 
                    steps {
                        dir('bugtracker-backend') {
                            sh '''
                            go test -v ./... 2>&1| go-junit-report > test-results.xml 

                            # generate the coverage report
                            go test -coverprofile=coverage.out -covermode=atomic ./...
                            go tool cover -html=coverage.out -o coverage.html

                            mkdir -p reports
                            mv coverage.html reports/
                            '''
                        }
                    }
                    post { 
                        always {
                            junit 'bugtracker-backend/test-results.xml' // publish the test results in the jenkins dashboard
                            publishHTML target: [
                                reportDir: 'bugtracker-backend/reports',
                                reportFiles: 'coverage.html',
                                reportName: 'Backend Coverage Report',
                            ]
                        }
                    }
                }
                
                stage('Unit Tests - Frontend') {
                    agent {
                        docker {
                            image 'node:20-alpine' // what it does is to run the tests and generate a junit report without the need to install node and npm in the jenkins agent
                            reuseNode true
                        }
                    }
                    steps {
                        dir('bugtracker-frontend') {
                            sh '''
                            npm ci
                            npm test
                            mkdir -p reports
                            mv coverage reports/
                            '''
                        }
                    }
                    post { // post is used for actions that should be executed after the steps are completed, regardless of whether they succeed or fail
                        always {
                            junit 'bugtracker-frontend/test-results.xml' // publish the test results in the jenkins dashboard
                            publishHTML target: [
                                reportDir: 'bugtracker-frontend/reports/coverage',
                                reportFiles: 'index.html',
                                reportName: 'Frontend Coverage Report',
                            ]
                        }
                    }
                }
            }
        }
        stage('Launch Application') {
            agent {
                docker {
                    image 'docker:27.5.1' 
                    reuseNode true
                    args '-v /var/run/docker.sock:/var/run/docker.sock -u 0' // mount the docker socket to be able to run docker commands inside the container
                }
            }
            steps {
                sh 'docker compose up --build -d '
            }
        }
        stage('API tests'){
            agent {
                docker {
                    image 'mcr.microsoft.com/playwright:v1.50.0-jammy'
                    reuseNode true
                    args '-u 0 --network=host'
                }
            }
            steps {
                dir('tests-api') {
                    sh 'npx wait-port http://localhost:8080/api/health -t 30000' // wait for the backend to be up and running before running the tests
                    
                    sh 'npm ci'
                    sh 'npx playwright test'
                }
            }
            post {
                always {
                    junit  'tests-api/test-results/results.xml' // publish the test results in the jenkins dashboard
                    publishHTML target: [
                        reportDir: 'tests-api/playwright-report',
                        reportFiles: 'index.html',
                        reportName: 'API Tests Report',
                    ]
                }
            }
        }
        stage('E2E Tests'){
            agent {
                docker {
                    image 'mcr.microsoft.com/playwright:v1.50.0-jammy'
                    reuseNode true
                    args '-u 0 --network=host'
                }
            }
            steps {
                dir('tests-e2e') {                    
                    sh 'npm ci'
                    sh 'npx playwright test'
                }
            }
            post {
                always {
                    junit  'tests-e2e/test-results/results.xml' // publish the test results in the jenkins dashboard
                    publishHTML target: [
                        reportDir: 'tests-e2e/playwright-report',
                        reportFiles: 'index.html',
                        reportName: 'E2E Tests Report',
                    ]
                }
            }
        }
        stage('Performance tests'){
            agent {
                docker {
                    image 'grafana/k6:lateset'
                    reuseNode true
                    args '-network=host -u root -entrypoint=""' // run the container with the host network to be able to access the backend and frontend services, and run it as root to be able to write the test results in the workspace
                }
            }
            steps {
                dir('tests-perf') {                    
                    sh 'k6 run script.js'
                }
            }
            post {
                always {
                    publishHTML target: [
                        reportDir: 'tests-perf',
                        reportFiles: 'perf-results.html',
                        reportName: 'Performance Tests Report',
                    ]
                }
        }
    }
    post {
        always {
            cleanWs() // clean the workspace after the build is completed
        }
    }
}